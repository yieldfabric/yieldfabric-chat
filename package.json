{
  "name": "yieldfabric-chat",
  "version": "0.1.0",
  "private": true,
  "description": "Reference implementation: a chat / LLM / agent app on YieldFabric, built with @yieldfabric/wallet and @yieldfabric/terminal.",
  "license": "MIT",
  "dependencies": {
    "@headlessui/react": "1.7.18",
    "@heroicons/react": "2.2.0",
    "@types/node": "16.18.86",
    "@types/react": "18.2.61",
    "@types/react-dom": "18.2.19",
    "@yieldfabric/terminal": "file:../../yieldfabric-terminal",
    "@yieldfabric/wallet": "file:../../yieldfabric-wallet-sdk",
    "framer-motion": "12.10.5",
    "js-sha3": "0.9.3",
    "lucide-react": "^0.294.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "^9.1.0",
    "react-router-dom": "6.22.3",
    "react-scripts": "5.0.1",
    "typescript": "4.9.5",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "autoprefixer": "10.4.14",
    "postcss": "8.4.31",
    "tailwindcss": "3.3.0"
  },
  "scripts": {
    "start": "craco start",
    "build": "craco build",
