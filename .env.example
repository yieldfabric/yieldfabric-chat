# ── YieldFabric service URLs ─────────────────────────────────────────
# Copy to `.env`. The values below point at the hosted platform; to run
# against a local YieldFabric stack instead, comment them out and
# uncomment the "Local stack" block at the bottom.

# Read by the wallet-SDK (sign-in, tokens, profile, keys).
REACT_APP_AUTH_SERVICE_URL=https://auth.yieldfabric.com
REACT_APP_PAYMENTS_SERVICE_URL=https://pay.yieldfabric.com
REACT_APP_API_URL=https://pay.yieldfabric.com

# Read by this app (chat, model catalog, history).
REACT_APP_AGENTS_API_URL=https://agents.yieldfabric.com

# Pin the local dev server to a stable port.
PORT=3020

# The in-app "docs ↗" tutorial links point here (see src/docs.ts).
# Override for a self-hosted docs site.
# REACT_APP_DOCS_BASE_URL=https://yieldfabric.com

# ── Local stack ──────────────────────────────────────────────────────
# Uncomment to run against a local YieldFabric stack instead of the
# hosted platform (and comment out the https://*.yieldfabric.com values
# above).
# REACT_APP_AUTH_SERVICE_URL=http://localhost:3000
# REACT_APP_PAYMENTS_SERVICE_URL=http://localhost:3002
# REACT_APP_API_URL=http://localhost:3002
# REACT_APP_AGENTS_API_URL=http://localhost:3001
